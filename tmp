+++ b/tools/include/uapi/linux/bpf.h
@@ -3983,6 +3983,9 @@ union bpf_attr {
 	FN(get_sk_rx_dst),		\
 	FN(xdp_set_skb_dst),		\
 	FN(change_skb_dev),		\
+	FN(km_strnstr),			\
+	FN(km_strncmp),			\
+	FN(parse_header_msg),		\
 	/* */
 
 /* integer value in 'imm' field of BPF_CALL instruction selects which helper
