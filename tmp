if (uname -r | grep oe2303); then
        cp oe2303/ko/kmesh.ko /lib/modules/$(uname -r)
        cp oe2303/*so* /usr/lib64/
        cp oe2303/kmesh-daemon /usr/bin/
        cp oe2303/kmesh-cni /usr/bin/
        cp oe2303/mdacore /usr/bin
else
        cp other/*so* /usr/lib64/
        cp other/kmesh-daemon /usr/bin/
        cp other/kmesh-cni /usr/bin/
        cp other/mdacore /usr/bin
fi
