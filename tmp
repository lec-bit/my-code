func checkMap64Count(adsObj *ads.BpfAds, t *testing.T) int {
	var count int
	var key uint32
	var value [64]byte
	kmeshMap64 := adsObj.SockConn.KmeshCgroupSockMaps.KmeshMap64
	iter := kmeshMap64.Iterate()
	for iter.Next(&key, &value) {
		count++
	}
	assert.Nil(t, iter.Err())
	return count
}

